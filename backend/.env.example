# ─── Django Core ────────────────────────────────────────────────────────────
SECRET_KEY=your-django-secret-key-here
DEBUG=False

# ─── Database ───────────────────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=planora_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ─── Email ──────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=support@planorah.me
BREVO_SENDER_NAME=Planorah

# OTP / transactional email service (used by users OTP + password reset flows)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=support@planorah.me
BREVO_SENDER_NAME=Planorah

# ─── Google & GitHub OAuth ──────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/users/google/callback/
# Production: https://api.planorah.me/api/users/google/callback/

# Optional dedicated Google Calendar OAuth keys (scheduler module).
# If unset, scheduler falls back to GOOGLE_OAUTH_CLIENT_ID/SECRET above.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/scheduler
# Production: https://planorah.me/scheduler

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ─── Frontend URLs ─────────────────────────────────────────────────────────
FRONTEND_URL=https://planorah.me
PORTFOLIO_FRONTEND_URL=https://portfolio.planorah.me
PORTFOLIO_PUBLIC_BASE_URL=https://portfolio.planorah.me
PORTFOLIO_PUBLIC_ROOT_DOMAIN=planorah.me

# ─── Gemini (AI assistant) ──────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Assistant v2 Pipeline (Gemini STT -> LLM -> TTS) ─────────────────────
AI_PIPELINE_ENABLED=false
AI_PIPELINE_CHANNELS=voice,text
AI_PIPELINE_ACTIONS_ENABLED=true
AI_PIPELINE_FALLBACK_REALTIME_ENABLED=true
AI_PIPELINE_DEFAULT_LANGUAGE=hinglish
AI_PIPELINE_MAX_FRONTEND_CONTEXT_BYTES=12000
AI_PIPELINE_MAX_BACKEND_CONTEXT_BYTES=32000
AI_PIPELINE_MAX_SESSION_TURNS=12
AI_PIPELINE_MAX_AUDIO_MB=8
AI_PIPELINE_STT_TIMEOUT_SEC=30
AI_PIPELINE_LLM_TIMEOUT_SEC=35
AI_PIPELINE_TTS_TIMEOUT_SEC=35
GEMINI_STT_MODEL=gemini-2.5-flash
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_DEFAULT_VOICE=Kore

# Celery / Redis (async assistant actions)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Voice Proxy (Gemini Live WebSocket) ────────────────────────────────────
# Host/port the standalone voice proxy binds to (nginx proxies externally)
VOICE_PROXY_HOST=127.0.0.1
VOICE_PROXY_PORT=8001
# Full public WebSocket URL returned to the frontend (set this in production!)
VOICE_PROXY_PUBLIC_URL=wss://voice.planorah.me/ws/voice
# Comma-separated allowed WebSocket origins. Leave empty to allow all (dev only).
VOICE_PROXY_ALLOWED_ORIGINS=https://planorah.me,https://www.planorah.me
# Optional setup timeouts (seconds)
VOICE_PROXY_CLIENT_SETUP_TIMEOUT_SEC=10
VOICE_PROXY_GEMINI_SETUP_TIMEOUT_SEC=20

# ─── AI Calling System ──────────────────────────────────────────────────────
# Choose one provider:  huskyvoice | vapi | retell | elevenlabs | bland
AI_CALL_PROVIDER=huskyvoice

# HuskyVoice.ai  (https://studio.huskyvoice.ai)
# Sign up → get API access from your account manager / hello@huskyvoice.ai
HUSKY_API_KEY=             # Bearer token from HuskyVoice dashboard
HUSKY_AGENT_ID=            # Agent ID from HuskyVoice studio
HUSKY_FROM_NUMBER=         # Your assigned caller number in +E.164 format, e.g. +917411765511
HUSKY_LANGUAGE=en          # Language: en | hi | hi-en | kn | ta | te …

# ─ Alternative providers (leave blank if using HuskyVoice) ──────────────────

# Vapi.ai
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=

# Retell.ai
RETELL_API_KEY=
RETELL_FROM_NUMBER=
RETELL_AGENT_ID=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_FROM_NUMBER=

# Bland.ai
BLAND_API_KEY=
BLAND_FROM_NUMBER=
