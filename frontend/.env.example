# OAuth
REACT_APP_GITHUB_CLIENT_ID=your_github_client_id
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# API
# Local dev: /api/  (proxied via package.json proxy)
# Production (set this in Vercel env vars):
REACT_APP_API_BASE_URL=https://planorah.me/api/

# Portfolio system frontend URL
REACT_APP_PORTFOLIO_URL=https://planorah-c65p.vercel.app

# Optional debug logs
REACT_APP_API_DEBUG=false
