# OAuth (required when REACT_APP_STRICT_ENV=true or in production builds)
REACT_APP_GITHUB_CLIENT_ID=Ov23ctPC9ZlwUvXMuyWM
REACT_APP_GOOGLE_CLIENT_ID=264947999944-g51jh43q1he66qlh8fkg00pkghb6fcg3.apps.googleusercontent.com

# API
# Recommended:
# - local dev:  http://127.0.0.1:8000
# - production: https://api.planorah.me
# Allowed formats:
#   REACT_APP_API_BASE_URL=https://api.planorah.me
#   REACT_APP_API_BASE_URL=http://127.0.0.1:8000
#   REACT_APP_API_BASE_URL=/api  (dev only, not allowed in production)
REACT_APP_API_BASE_URL=

# Env strictness (defaults to true in production builds)
# true  -> fail fast on missing/invalid required env vars
# false -> allow non-production fallbacks
REACT_APP_STRICT_ENV=false

# Portfolio system frontend URL
REACT_APP_PORTFOLIO_URL=https://portfolio.planorah.me

# Optional debug logs
REACT_APP_API_DEBUG=false
