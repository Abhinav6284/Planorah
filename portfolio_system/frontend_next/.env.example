# Public portfolio API base URL (must include /v1)
NEXT_PUBLIC_PORTFOLIO_API_BASE=http://localhost:8000/v1

# Server-side internal API base — used for custom domain SSR lookups.
# On the VPS this can be the loopback address to avoid the public network.
PORTFOLIO_API_INTERNAL_BASE=http://127.0.0.1:8000/v1

# Next.js middleware host routing for wildcard portfolio subdomains
PORTFOLIO_ROOT_DOMAIN=planorah.me
PORTFOLIO_RESERVED_SUBDOMAINS=www,api,voice,portfolio,app
