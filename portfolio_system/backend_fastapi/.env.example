# Copy this file to .env and update values for your environment.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_NAME=planorah-portfolio-api
ENV=production
DEBUG=false
API_V1_PREFIX=/v1

# -----------------------------------------------------------------------------
# Auth / database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/planorah_portfolio
JWT_SECRET=replace-me
JWT_ALGORITHM=HS256
AUTO_CREATE_SCHEMA=false

# -----------------------------------------------------------------------------
# Media
# -----------------------------------------------------------------------------
MEDIA_ROOT=/var/www/planorah/media
MEDIA_URL_PATH=/media
PUBLIC_API_BASE_URL=https://api.planorah.me
MAX_UPLOAD_BYTES=8388608

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated exact origins.
ALLOWED_ORIGINS=https://portfolio.planorah.me,https://planorah.me,http://localhost:3000,http://127.0.0.1:3000
# Wildcard subdomains like https://xyz.planorah.me
ALLOWED_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?planorah\.me$
# Optional Vercel preview domains
VERCEL_ORIGIN_REGEX=https://.*\\.vercel\\.app
