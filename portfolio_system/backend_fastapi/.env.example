APP_NAME=planorah-portfolio-api
ENV=production
DEBUG=false
API_V1_PREFIX=/v1

DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/planorah_portfolio
JWT_SECRET=replace-me
JWT_ALGORITHM=HS256

MEDIA_ROOT=/var/www/planorah/media
MEDIA_URL_PATH=/media
PUBLIC_API_BASE_URL=https://api.planorah.me
MAX_UPLOAD_BYTES=8388608

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://portfolio.planorah.me,https://planorah.me,http://localhost:3000
VERCEL_ORIGIN_REGEX=https://.*\\.vercel\\.app
