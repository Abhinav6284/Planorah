APP_NAME=planorah-portfolio-api
ENV=development
DEBUG=true
API_V1_PREFIX=/v1
JWT_SECRET_KEY=replace-me
JWT_ALGORITHM=HS256
POSTGRES_DSN=postgresql+psycopg://postgres:postgres@localhost:5432/planorah
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_BUCKET=planorah-portfolio-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=
CDN_BASE_URL=https://cdn.planorah.me
MAX_UPLOAD_BYTES=8388608
PUBLIC_CACHE_TTL_SECONDS=300
